{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "excludeFiles": "public/**"
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/supabase-config", "dest": "/api/index.js" },
    { "src": "/(.*\\.(html|css|js|png|jpg|jpeg|gif|svg|ico|webp|woff2?|ttf|eot|json|map))$", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
